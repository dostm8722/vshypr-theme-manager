    def _page_wallpaper(self):
        t = self._theme

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.set_margin_start(24); outer.set_margin_end(24)
        outer.set_margin_top(20);   outer.set_margin_bottom(20)

        hdr_lbl = Gtk.Label()
        hdr_lbl.set_markup(
            f'<span foreground="{t["txt"]}" weight="bold" size="16000">Wallpaper</span>'
        )
        hdr_lbl.set_halign(Gtk.Align.START)
        outer.pack_start(hdr_lbl, False, False, 0)

        sub = Gtk.Label()
        sub.set_markup(
            f'<span foreground="{t["dim"]}" size="12000">'
            f'Select and apply a wallpaper with awww (fade transition)</span>'
        )
        sub.set_halign(Gtk.Align.START)
        sub.set_margin_bottom(16)
        outer.pack_start(sub, False, False, 0)

        # ── Image path ────────────────────────────────────────────────────────
        outer.pack_start(_section("WALLPAPER IMAGE"), False, False, 0)

        try:
            cur_wp = _json.loads(open(_TC_CURRENT).read()).get("wallpaper") or ""
        except Exception:
            cur_wp = ""

        _selected = [cur_wp]

        file_row  = Gtk.Box(spacing=8)
        file_row.set_margin_top(6)
        wp_entry  = Gtk.Entry()
        wp_entry.set_text(cur_wp)
        wp_entry.set_hexpand(True)
        wp_entry.set_placeholder_text("Path to image...")

        browse_btn = Gtk.Button(label=" Browse")
        browse_btn.get_style_context().add_class("open-btn")

        # ── Preview area ──────────────────────────────────────────────────────
        _PW, _PH = 520, 292   # 16:9
        _pixbuf  = [None]

        preview_box = Gtk.Box()
        preview_box.get_style_context().add_class("preview-box")
        preview_box.set_margin_top(12)

        preview_da = Gtk.DrawingArea()
        preview_da.set_size_request(_PW, _PH)

        def _load_preview(path):
            try:
                pb = GdkPixbuf.Pixbuf.new_from_file_at_scale(path, _PW, _PH, True)
                _pixbuf[0] = pb
            except Exception:
                _pixbuf[0] = None
            preview_da.queue_draw()
            return False   # para GLib.idle_add

        _clr_hdr = _hex_to_rgb(t["hdr"])
        _clr_brd = _hex_to_rgb(t["brd"])
        _clr_mid = _hex_to_rgb(t["mid"])

        def _draw(widget, cr):
            w = widget.get_allocated_width()
            h = widget.get_allocated_height()
            cr.set_source_rgb(*_clr_hdr)
            cr.rectangle(0, 0, w, h)
            cr.fill()
            if _pixbuf[0]:
                pb  = _pixbuf[0]
                ox  = (w - pb.get_width())  // 2
                oy  = (h - pb.get_height()) // 2
                Gdk.cairo_set_source_pixbuf(cr, pb, ox, oy)
                cr.paint()
            else:
                cr.set_source_rgb(*_clr_brd)
                cr.set_line_width(1)
                cr.rectangle(0.5, 0.5, w - 1, h - 1)
                cr.stroke()
                cr.set_source_rgb(*_clr_mid)
                cr.select_font_face(
                    "monospace", cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_NORMAL
                )
                cr.set_font_size(13)
                msg = "No image selected"
                xb, yb, tw, th2, _, _ = cr.text_extents(msg)
                cr.move_to((w - tw) / 2 - xb, (h + th2) / 2 - yb)
                cr.show_text(msg)

        preview_da.connect("draw", _draw)
        preview_box.pack_start(preview_da, True, True, 0)
        outer.pack_start(preview_box, False, False, 0)

        def _on_entry_changed(entry):
            path = entry.get_text().strip()
            _selected[0] = path
            if path and os.path.isfile(path):
                _load_preview(path)
            else:
                _pixbuf[0] = None
                preview_da.queue_draw()

        wp_entry.connect("changed", _on_entry_changed)

        def _browse(*_):
            dlg = Gtk.FileChooserDialog(
                title="Select wallpaper", parent=self,
                action=Gtk.FileChooserAction.OPEN
            )
            dlg.add_button("Cancel", Gtk.ResponseType.CANCEL)
            dlg.add_button("Select", Gtk.ResponseType.OK)

            flt = Gtk.FileFilter()
            flt.set_name("Images (JPG, PNG, WebP)")
            for mime in ("image/jpeg", "image/png", "image/webp"):
                flt.add_mime_type(mime)
            for pat in ("*.jpg", "*.jpeg", "*.png", "*.webp"):
                flt.add_pattern(pat)
            dlg.add_filter(flt)

            wp_dir = self._cfg.get("wallpapers_dir", _DEFAULT_WP_DIR)
            if os.path.isdir(wp_dir):
                dlg.set_current_folder(wp_dir)
            elif cur_wp and os.path.isfile(cur_wp):
                dlg.set_filename(cur_wp)

            if dlg.run() == Gtk.ResponseType.OK:
                wp_entry.set_text(dlg.get_filename())
            dlg.destroy()

        browse_btn.connect("clicked", _browse)
        file_row.pack_start(wp_entry,   True,  True,  0)
        file_row.pack_start(browse_btn, False, False, 0)
        outer.pack_start(file_row, False, False, 0)

        # Load initial preview
        if cur_wp and os.path.isfile(cur_wp):
            GLib.idle_add(lambda: _load_preview(cur_wp))

        # ── Apply ─────────────────────────────────────────────────────────────
        outer.pack_start(_section("APPLY"), False, False, 0)

        awww_ok = bool(shutil.which("awww"))
        if not awww_ok:
            warn = Gtk.Label()
            warn.set_markup(
                f'<span foreground="{t["yellow"]}" size="11000">'
                f'⚠  awww not found — install it from the Setup tab</span>'
            )
            warn.set_halign(Gtk.Align.START)
            warn.set_margin_top(4)
            outer.pack_start(warn, False, False, 0)

        action_row = Gtk.Box(spacing=10)
        action_row.set_margin_top(10)
        action_row.pack_start(Gtk.Box(), True, True, 0)

        apply_btn = Gtk.Button()
        apply_btn.get_style_context().add_class("save-btn")
        apply_btn.set_sensitive(awww_ok)
        apply_lbl = Gtk.Label()
        apply_lbl.set_markup(
            '<span font_desc="JetBrainsMono Nerd Font 13">  Apply wallpaper</span>'
        )
        apply_btn.add(apply_lbl)

        def _apply_wp(*_):
            path = _selected[0].strip()
            if not path or not os.path.isfile(path):
                self._set_status("Select a valid image first")
                return
            try:
                subprocess.Popen(
                    ["awww-daemon", "--daemon"],
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
                )
            except Exception:
                pass
            try:
                subprocess.Popen(
                    ["awww", "img", path,
                     "--transition-type", "fade"],
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
                )
                self._set_status(f"Wallpaper applied: {os.path.basename(path)}")
            except Exception as e:
                self._set_status(f"Error applying wallpaper: {e}")

        apply_btn.connect("clicked", _apply_wp)
        action_row.pack_start(apply_btn, False, False, 0)
        outer.pack_start(action_row, False, False, 0)

        return _scrolled(outer)

