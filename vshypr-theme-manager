        # ── rofi-picker.sh patch ──────────────────────────────────────────────
        # Defined before _save so _save can call it.
        def _do_patch_rofi():
            """Applies self._cfg values to rofi-picker.sh. Returns error msg or None."""
            rofi_sh = os.path.join(
                self._cfg.get("theme_changer_dir", _USER_DATA_DIR), "rofi-picker.sh"
            )
            if not os.path.isfile(rofi_sh):
                return f"Not found: {rofi_sh}"
            with open(rofi_sh) as f:
                lines = f.readlines()

            new_wp_dir  = self._cfg.get("wallpapers_dir", _DEFAULT_WP_DIR)
            new_rasi_tp = self._cfg.get("rasi_theme_picker", "~/.config/rofi/theme-picker.rasi")
            new_rasi_wp = self._cfg.get("rasi_wallpaper_picker", "~/.config/rofi/wallpaper-picker.rasi")

            for i, line in enumerate(lines):
                # 1. Wallpapers folder — line with WALLPAPERS and find
                if 'WALLPAPERS' in line and 'find' in line:
                    lines[i] = re.sub(
                        r'(find\s+)"[^"]*"',
                        lambda m: m.group(1) + f'"{new_wp_dir}"',
                        line
                    )
                # 2. Theme picker rasi — -theme line followed by > /tmp/...
                #    The next non-empty line starts with '>'
                elif '-theme' in line:
                    next_nonempty = next(
                        (lines[j].lstrip() for j in range(i + 1, min(i + 3, len(lines)))
                         if lines[j].strip()),
                        ""
                    )
                    if next_nonempty.startswith('>'):
                        lines[i] = re.sub(
                            r'(-theme\s+)\S+',
                            lambda m: m.group(1) + new_rasi_tp,
                            line
                        )
                    # 3. Wallpaper picker rasi — -theme line ending in ')'
                    #    (closing of command substitution WP_IDX=$(...))
                    elif line.rstrip().endswith(')'):
                        lines[i] = re.sub(
                            r'(-theme\s+)[^\s)]+',
                            lambda m: m.group(1) + new_rasi_wp,
                            line
                        )

            with open(rofi_sh, "w") as f:
                f.writelines(lines)
            return None  # sin error

        # ── Save ──────────────────────────────────────────────────────────────
        save_row = Gtk.Box()
        save_row.set_margin_top(24)

        save_btn = Gtk.Button(label="Save and apply to rofi-picker.sh")
