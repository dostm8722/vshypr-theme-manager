    def _page_hub(self, auto_fetch=True):
        t    = self._theme
        _aur = next((h for h in ("yay", "paru") if shutil.which(h)), None)

        _MANIFEST_URL   = "https://raw.githubusercontent.com/victorsosaMx/vsHub/main/tools.json"
        _CACHE_PATH     = os.path.expanduser("~/.cache/vshub/tools.json")
        _FALLBACK_TOOLS = [
            {
                "name": "vsHyprland-Manager",
                "desc": "Graphical config editor for Hyprland",
                "icon": "󱙌", "exe": "vshyprland", "aur": "vshyprland-manager",
                "github": "https://github.com/victorsosaMx/vsHyprland-Manager",
            },
            {
                "name": "vsWaybar Studio",
                "desc": "Graphical config editor for Waybar",
                "icon": "󰣇", "exe": "vswaybar-studio", "aur": "vswaybar-studio",
                "github": "https://github.com/victorsosaMx/vsWaybar-Studio",
            },
            {
                "name": "vsFetch",
                "desc": 'Graphical system info viewer — like "About This Computer" for your Linux desktop',
                "icon": "󰟀", "exe": "vsfetch", "aur": "vsfetch",
                "github": "https://github.com/victorsosaMx/vsFetch",
            },
            {
                "name": "vsFetch Settings",
                "desc": "Visual config editor for vsFetch — live preview, themes, no JSON editing",
                "icon": "󰒓", "exe": "vsfetch-settings", "aur": "vsfetch-settings",
                "github": "https://github.com/victorsosaMx/vsFetch-Settings",
            },
            {
                "name": "vsHypr Theme Manager",
                "desc": "Theming system for Arch Linux + Hyprland — you are here",
                "icon": "󰔯", "exe": "vshypr-theme-manager", "aur": "vshypr-theme-manager",
                "github": "https://github.com/victorsosaMx/vsHypr-Theme-Manager",
                "self": True,
            },
        ]

        def _load_tools():
            try:
                with open(_CACHE_PATH) as f:
                    return _json.load(f)
            except Exception:
                return _FALLBACK_TOOLS

        def _fetch_manifest():
            try:
                req = urllib.request.Request(
                    _MANIFEST_URL,
                    headers={"User-Agent": "vshypr-theme-manager/" + __version__}
                )
                with urllib.request.urlopen(req, timeout=8) as r:
                    data = r.read().decode()
                remote = _json.loads(data)
                os.makedirs(os.path.dirname(_CACHE_PATH), exist_ok=True)
                with open(_CACHE_PATH, "w") as f:
                    _json.dump(remote, f, indent=2)
                GLib.idle_add(lambda: self._reload_hub_tab(switch_to_hub=False))
                GLib.idle_add(lambda: self._set_status(f"vsHub updated — {len(remote)} tools"))
            except Exception as e:
                GLib.idle_add(lambda: self._set_status(f"vsHub: error fetching list — {e}"))

        def _build_cards(tools, container):
            for tool in tools:
                is_self      = tool.get("self", False)
                is_installed = is_self or bool(shutil.which(tool.get("exe", "")))

                card = _card_box(active=(is_self or is_installed))
                card.set_margin_bottom(10)

                row = Gtk.Box(spacing=12)
                row.set_margin_start(14); row.set_margin_end(14)
                row.set_margin_top(10);   row.set_margin_bottom(10)

                icon_lbl = Gtk.Label()
                icon_lbl.set_markup(
                    f'<span font_desc="JetBrainsMono Nerd Font 20" '
                    f'foreground="{t["acc"] if (is_self or is_installed) else t["dim"]}">'
                    f'{tool.get("icon", "")}</span>'
                )
                row.pack_start(icon_lbl, False, False, 0)

                info = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
                n = Gtk.Label()
                n.set_markup(
                    f'<span foreground="{t["txt"]}" weight="bold" size="13000">'
                    f'{tool.get("name", "")}</span>'
                )
                n.set_halign(Gtk.Align.START)
                d = Gtk.Label()
                d.set_markup(
                    f'<span foreground="{t["dim"]}" size="11000">{tool.get("desc", "")}</span>'
                )
                d.set_halign(Gtk.Align.START)
                info.pack_start(n, False, False, 0)
                info.pack_start(d, False, False, 0)
                row.pack_start(info, True, True, 0)

                if is_self:
                    dot = Gtk.Label()
                    dot.set_markup(
                        f'<span foreground="{t["acc"]}">● </span>'
                        f'<span foreground="{t["dim"]}" size="11000">you are here</span>'
                    )
                    row.pack_start(dot, False, False, 0)
                elif is_installed:
                    dot = Gtk.Label()
                    dot.set_markup(f'<span foreground="{t["acc"]}">●</span>')
                    row.pack_start(dot, False, False, 4)
                    launch = Gtk.Button(label="Launch →")
                    launch.get_style_context().add_class("save-btn")
                    launch.connect("clicked",
                        lambda *_, exe=tool.get("exe", ""): subprocess.Popen(
                            [exe], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
                        ))
                    row.pack_start(launch, False, False, 0)
                else:
                    dot = Gtk.Label()
                    dot.set_markup(f'<span foreground="{t["mid"]}">○</span>')
                    row.pack_start(dot, False, False, 4)
                    gh = Gtk.Button(label="GitHub")
                    gh.get_style_context().add_class("open-btn")
                    gh.connect("clicked",
                        lambda *_, url=tool.get("github", ""): _open_url(url))
                    row.pack_start(gh, False, False, 0)
                    inst = Gtk.Button(label=f"Install ({_aur or 'AUR'})")
                    inst.get_style_context().add_class("open-btn")
                    inst.set_sensitive(_aur is not None)
                    inst.set_tooltip_text(
                        f"{_aur} -S {tool.get('aur', '')}" if _aur
                        else "yay or paru not found"
                    )
                    inst.connect("clicked",
                        lambda *_, pkg=tool.get("aur", ""): self._run_in_terminal(
                            [f"{_aur} -S {pkg}"], on_done=self._reload_hub_tab
                        ))
                    row.pack_start(inst, False, False, 0)

                card.pack_start(row, False, False, 0)
