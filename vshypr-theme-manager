def _init_user_data():
    """Primera ejecución: copia datos del sistema a ~/.config/vshypr-theme-manager/.

    En modo desarrollo (_SYSTEM_DATA_DIR no existe) no hace nada — los archivos
    ya están junto al ejecutable en el repo.
    """
    os.makedirs(_USER_DATA_DIR, exist_ok=True)
    if not os.path.isdir(_SYSTEM_DATA_DIR):
        return
    for item in ("vshypr-theme-manager.py", "rofi-picker.sh", "themes", "templates", "assets"):
        src = os.path.join(_SYSTEM_DATA_DIR, item)
        dst = os.path.join(_USER_DATA_DIR, item)
        if not os.path.exists(src):
            continue
        if os.path.isdir(src):
            if not os.path.exists(dst):
                shutil.copytree(src, dst)
        else:
            if not os.path.isfile(dst):
                shutil.copy2(src, dst)


_init_user_data()

# ── persistent state ─────────────────────────────────────────────────────────

def _state_get(key, default=None):
    try:
        return _json.loads(open(_F_STATE).read()).get(key, default)
    except Exception:
        return default

def _state_set(key, value):
    try:
        data = _json.loads(open(_F_STATE).read())
    except Exception:
        data = {}
    data[key] = value
    with open(_F_STATE, "w") as f:
        f.write(_json.dumps(data, indent=2))

def _config_load():
    try:
        return _json.loads(open(_F_CONFIG).read())
    except Exception:
        return {}

def _config_save(cfg):
    os.makedirs(os.path.dirname(_F_CONFIG), exist_ok=True)
    with open(_F_CONFIG, "w") as f:
        _json.dump(cfg, f, indent=2)

