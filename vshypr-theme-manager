            except Exception as e:
                self._set_status(f"Save error: {e}")
                return
            try:
                err = _do_patch_rofi()
                if err:
                    self._set_status(f"Config saved — {err}")
                else:
                    self._set_status("Config saved and applied to rofi-picker.sh")
            except Exception as e:
