        )

        patch_btn = Gtk.Button(label="Re-apply now")
        patch_btn.get_style_context().add_class("open-btn")
        patch_btn.set_margin_top(8)

        def _patch_rofi(*_):
            try:
                err = _do_patch_rofi()
                self._set_status(err if err else "rofi-picker.sh updated")
            except Exception as e:
                self._set_status(f"Error: {e}")

        patch_btn.connect("clicked", _patch_rofi)
        outer.pack_start(patch_btn, False, False, 0)

