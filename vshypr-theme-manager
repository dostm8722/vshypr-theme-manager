            inner.pack_start(_make_thumb(theme_dir), False, False, 0)

            # paleta swatches
            inner.pack_start(_make_swatch_row(colors), False, False, 0)

            name_lbl = Gtk.Label()
            name_lbl.set_markup(
                f'<span foreground="{t["acc"] if is_cur else t["txt"]}" '
                f'weight="{"bold" if is_cur else "normal"}" size="11500">{display_name}</span>'
            )
            name_lbl.set_halign(Gtk.Align.CENTER)
            name_lbl.set_ellipsize(Pango.EllipsizeMode.END)
            name_lbl.set_max_width_chars(18)
            name_lbl.set_margin_top(2)
            inner.pack_start(name_lbl, False, False, 0)

            # botones
            btn_row = Gtk.Box(spacing=4)
            btn_row.set_halign(Gtk.Align.CENTER)
            btn_row.set_margin_top(4)

            apply_btn = Gtk.Button(label="Apply")
            apply_btn.get_style_context().add_class("open-btn")
            apply_btn.connect("clicked", lambda *_: _apply_theme(name))

            wp_path = _find_theme_wallpaper(theme_dir)
            is_dynamic = name.startswith("dynamic-")

            btn_row.pack_start(apply_btn, False, False, 0)
            if wp_path or is_dynamic:
                wp_btn = Gtk.Button(label="+ WP")
                wp_btn.get_style_context().add_class("save-btn")
                if wp_path:
                    wp_btn.connect("clicked", lambda *_, _n=name, _w=wp_path: _apply_theme(_n, _w))
                else:
                    wp_btn.connect("clicked", lambda *_, _n=name: _pick_wallpaper_and_apply(_n))
                btn_row.pack_start(wp_btn, False, False, 0)

            inner.pack_start(btn_row, False, False, 0)
            card.pack_start(inner, False, False, 0)
            return card

        # ── Load and group themes ─────────────────────────────────────────────
        dark_themes, light_themes, dyn_themes = [], [], []

        try:
            entries = sorted([
                d for d in os.listdir(_TC_THEMES)
                if os.path.isdir(os.path.join(_TC_THEMES, d))
                and os.path.isfile(os.path.join(_TC_THEMES, d, "colors.json"))
            ])
        except Exception:
            entries = []

        for name in entries:
            td = os.path.join(_TC_THEMES, name)
            try:
                with open(os.path.join(td, "colors.json")) as _f:
                    meta = _json.load(_f)
                _meta_sec = meta.get("meta", {})
                variant      = _meta_sec.get("variant", "dark")
                display_name = _meta_sec.get("display_name", name)
                colors       = meta.get("colors", {})
            except Exception:
                variant, display_name, colors = "dark", name, {}
            if name.startswith("dynamic-"):
                dyn_themes.append((name, display_name, colors, td))
            elif variant == "light":
                light_themes.append((name, display_name, colors, td))
            else:
                dark_themes.append((name, display_name, colors, td))

        def _add_group(label_text, group):
            if not group:
                return
            outer.pack_start(_section(label_text), False, False, 0)
            flow = Gtk.FlowBox()
            flow.set_max_children_per_line(4)
            flow.set_selection_mode(Gtk.SelectionMode.NONE)
            flow.set_row_spacing(8)
            flow.set_column_spacing(8)
            flow.set_margin_top(8)
            flow.set_homogeneous(True)
            for name, display_name, colors, td in group:
                card = _make_theme_card(name, display_name, name == cur_name, colors, td)
                flow.add(card)
            outer.pack_start(flow, False, False, 0)

        _add_group("DARK",    dark_themes)
        _add_group("LIGHT",   light_themes)
        _add_group("DYNAMIC", dyn_themes)

        return _scrolled(outer)

