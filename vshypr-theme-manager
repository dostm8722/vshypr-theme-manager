        hdr_row.set_margin_bottom(4)
        hdr_lbl = Gtk.Label()
        hdr_lbl.set_markup(
            f'<span foreground="{t["txt"]}" weight="bold" size="16000">vsHub</span>'
        )
        hdr_lbl.set_halign(Gtk.Align.START)
        hdr_row.pack_start(hdr_lbl, True, True, 0)

        refresh = Gtk.Button(label="⟳")
        refresh.get_style_context().add_class("open-btn")
        refresh.set_tooltip_text("Refresh list from GitHub")
        def _force_refresh(*_):
            try:
                os.remove(_CACHE_PATH)
            except Exception:
                pass
            self._set_status("vsHub: fetching list from GitHub…")
            threading.Thread(target=_fetch_manifest, daemon=True).start()
        refresh.connect("clicked", _force_refresh)
        hdr_row.pack_start(refresh, False, False, 0)
        outer.pack_start(hdr_row, False, False, 0)

        sub = Gtk.Label()
        sub.set_markup(
            f'<span foreground="{t["dim"]}" size="12000">'
            f'The vs ecosystem — all tools in one place</span>'
        )
        sub.set_halign(Gtk.Align.START)
        sub.set_margin_bottom(20)
        outer.pack_start(sub, False, False, 0)

        src = Gtk.Label()
        try:
            mtime = datetime.datetime.fromtimestamp(os.path.getmtime(_CACHE_PATH))
            src.set_markup(
                f'<span foreground="{t["dim"]}" size="10000">'
                f'Actualizado {mtime.strftime("%Y-%m-%d %H:%M")}</span>'
            )
        except OSError:
            src.set_markup(
                f'<span foreground="{t["dim"]}" size="10000">'
                f'Built-in list · fetching updates…</span>'
            )
        src.set_halign(Gtk.Align.START)
        src.set_margin_bottom(12)
        outer.pack_start(src, False, False, 0)

        _build_cards(_load_tools(), outer)
        if auto_fetch:
            threading.Thread(target=_fetch_manifest, daemon=True).start()

        return _scrolled(outer)

    # ══════════════════════════════════════════════════════════════════════════
    # PAGE:Commands
    # ══════════════════════════════════════════════════════════════════════════

    def _page_commands(self):
        t = self._theme

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.set_margin_start(24); outer.set_margin_end(24)
        outer.set_margin_top(20);   outer.set_margin_bottom(20)

        hdr_lbl = Gtk.Label()
        hdr_lbl.set_markup(
            f'<span foreground="{t["txt"]}" weight="bold" size="16000">Commands</span>'
        )
        hdr_lbl.set_halign(Gtk.Align.START)
        outer.pack_start(hdr_lbl, False, False, 0)

        sub = Gtk.Label()
        sub.set_markup(
            f'<span foreground="{t["dim"]}" size="12000">'
            f'Quick reference · integrations · restore configuration</span>'
        )
        sub.set_halign(Gtk.Align.START)
        sub.set_margin_bottom(4)
        outer.pack_start(sub, False, False, 0)

        tc_dir   = self._cfg.get("theme_changer_dir", _USER_DATA_DIR)
        gui_path = os.path.join(tc_dir, "vshypr-theme-manager")
        py_path  = os.path.join(tc_dir, "vshypr-theme-manager.py")
        rofi_path = os.path.join(tc_dir, "rofi-picker.sh")

        def _copy_btn(text):
            btn = Gtk.Button(label="󰆏 Copiar")
            btn.get_style_context().add_class("open-btn")
            btn.set_tooltip_text(text)
            def _do_copy(*_):
                cb = Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD)
                cb.set_text(text, -1)
                self._set_status(f"Copied: {text[:60]}{'…' if len(text)>60 else ''}")
            btn.connect("clicked", _do_copy)
            return btn

        def _cmd_row(label, cmd, hint=""):
            box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            box.set_margin_top(8)
            if hint:
                h = _hint(hint)
                box.pack_start(h, False, False, 0)
            row = Gtk.Box(spacing=8)
            code = Gtk.Label()
            code.set_markup(
                f'<span font_desc="JetBrains Mono 11" foreground="{t["acc"]}">{label}  </span>'
                f'<span font_desc="JetBrains Mono 11" foreground="{t["txt"]}">{cmd}</span>'
            )
            code.set_halign(Gtk.Align.START)
            code.set_selectable(True)
            row.pack_start(code,         True,  True,  0)
            row.pack_start(_copy_btn(cmd), False, False, 0)
            box.pack_start(row, False, False, 0)
            return box

        # ── Hyprland integration ──────────────────────────────────────────────
        outer.pack_start(_section("HYPRLAND INTEGRATION"), False, False, 0)
        outer.pack_start(_hint("Add these lines to your hyprland.conf (or your keybinds file)"), False, False, 0)

        hypr_cmds = [
            ("super+F1  →  rofi picker",
             f"bind = $mainMod, F1, exec, bash {rofi_path}",
             "Opens the visual theme picker with rofi"),
            ("super+shift+F1  →  open GUI",
             f"bind = $mainMod SHIFT, F1, exec, {gui_path}",
             "Opens vsHypr Theme Manager"),
            ("super+F2  →  dynamic dark theme",
             f"bind = $mainMod, F2, exec, python3 {py_path} dynamic-dark",
             "Applies dynamic dark theme with the current wallpaper"),
            ("super+F3  →  dynamic light theme",
             f"bind = $mainMod, F3, exec, python3 {py_path} dynamic-light",
             "Applies dynamic light theme with the current wallpaper"),
        ]
        for label, cmd, hint in hypr_cmds:
            outer.pack_start(_cmd_row(label, cmd, hint), False, False, 0)

        # ── Terminal commands ─────────────────────────────────────────────────
        outer.pack_start(_section("TERMINAL"), False, False, 0)

        term_cmds = [
            ("Open visual picker",
             f"bash {rofi_path}",
             ""),
            ("Open GUI",
             f"{gui_path}",
             ""),
            ("Apply theme",
             f"python3 {py_path} <theme-name>",
             "Example: python3 … catppuccin-mocha"),
            ("Apply theme + wallpaper",
             f"python3 {py_path} <theme-name> /path/to/wallpaper.jpg",
             ""),
            ("Dynamic dark theme",
             f"python3 {py_path} dynamic-dark /path/to/wallpaper.jpg",
             "Generates palette with matugen from the wallpaper"),
            ("Dynamic light theme",
             f"python3 {py_path} dynamic-light /path/to/wallpaper.jpg",
             ""),
            ("List available themes",
             f"python3 {py_path} --list",
             ""),
        ]
        for label, cmd, hint in term_cmds:
            outer.pack_start(_cmd_row(label, cmd, hint), False, False, 0)

        # ── Autostart ─────────────────────────────────────────────────────────
        outer.pack_start(_section("AUTOSTART (HYPRLAND)"), False, False, 0)
        outer.pack_start(_hint("Applies the last saved theme on session start"), False, False, 0)

        _current_json = os.path.join(tc_dir, "current-theme.json")
        cur_theme_cmd = "exec-once = bash -c 'sleep 2 && python3 " + py_path + " $(jq -r .theme " + _current_json + ")'"
        outer.pack_start(_cmd_row("exec-once", cur_theme_cmd, ""), False, False, 0)

        # ── Restore original configuration ───────────────────────────────────
        outer.pack_start(_section("RESTORE ORIGINAL CONFIGURATION"), False, False, 0)

        backup_original = os.path.join(tc_dir, "backups", "original")
        has_backup = os.path.isdir(backup_original) and bool(os.listdir(backup_original))

        if has_backup:
            try:
                files = []
                for root, _, fnames in os.walk(backup_original):
                    for f in fnames:
                        rel = os.path.relpath(os.path.join(root, f), backup_original)
                        files.append(rel)
                count = len(files)
            except Exception:
                count = 0

            info_lbl = Gtk.Label()
            info_lbl.set_markup(
                f'<span foreground="{t["dim"]}" size="12000">'
                f'Found <b>{count}</b> original files in '
                f'<tt>backups/original/</tt> — captured before the first apply.</span>'
            )
            info_lbl.set_halign(Gtk.Align.START)
            info_lbl.set_line_wrap(True)
            info_lbl.set_margin_top(6)
            outer.pack_start(info_lbl, False, False, 0)

            restore_row = Gtk.Box(spacing=8)
            restore_row.set_margin_top(10)

            open_btn = Gtk.Button(label="󰉋 Open backups folder")
            open_btn.get_style_context().add_class("open-btn")
            open_btn.connect("clicked", lambda *_: _open_url(f"file://{backup_original}"))

            restore_btn = Gtk.Button(label="󰜄 Restore original config")
            restore_btn.get_style_context().add_class("save-btn")

            restore_warn = Gtk.Label()
            restore_warn.set_markup(
                f'<span foreground="{t["dim"]}" size="11000" font_style="italic">'
                f'Will overwrite current files in ~/.config/</span>'
            )
            restore_warn.set_halign(Gtk.Align.START)
            restore_warn.set_margin_top(4)

            def _do_restore(*_):
                cfg_dir = os.path.expanduser("~/.config")
                restored, failed = [], []
                for root, _, fnames in os.walk(backup_original):
                    for fname in fnames:
                        src = os.path.join(root, fname)
                        rel = os.path.relpath(src, backup_original)
                        dst = os.path.join(cfg_dir, rel)
                        try:
                            os.makedirs(os.path.dirname(dst), exist_ok=True)
                            shutil.copy2(src, dst)
                            restored.append(rel)
                        except Exception as e:
                            failed.append(f"{rel}: {e}")
                if failed:
                    self._set_status(f"Restored {len(restored)}, errors: {len(failed)}")
                else:
                    self._set_status(f"✓ {len(restored)} files restored from backups/original/")

            restore_btn.connect("clicked", _do_restore)
            restore_row.pack_start(open_btn,    False, False, 0)
            restore_row.pack_start(restore_btn, False, False, 0)
            outer.pack_start(restore_row,  False, False, 0)
            outer.pack_start(restore_warn, False, False, 0)
        else:
            no_backup = Gtk.Label()
            no_backup.set_markup(
                f'<span foreground="{t["dim"]}" size="12000">'
                f'<tt>backups/original/</tt> not found — it is created automatically '
                f'on the first theme apply.</span>'
            )
            no_backup.set_halign(Gtk.Align.START)
            no_backup.set_margin_top(6)
            outer.pack_start(no_backup, False, False, 0)

        return _scrolled(outer)

