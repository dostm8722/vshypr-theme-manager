# ── UI helpers ──────────────────────────────────────────────────────────────────

def _scrolled(child):
    sw = Gtk.ScrolledWindow()
    sw.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    sw.add(child)
    return sw

def _card_box(active=False):
    """Box with guaranteed CSS background in GTK3.

    Gtk.Box has no GDK window of its own and does not render background-color
    automatically. By connecting 'draw' and calling Gtk.render_background /
    Gtk.render_frame we force painting before children are drawn.
    """
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    box.get_style_context().add_class(
        "plugin-card-active" if active else "plugin-card"
    )

    def _draw(widget, cr):
        ctx = widget.get_style_context()
        w   = widget.get_allocated_width()
        h   = widget.get_allocated_height()
        Gtk.render_background(ctx, cr, 0, 0, w, h)
        Gtk.render_frame(ctx, cr, 0, 0, w, h)
        return False   # False = keep propagating to draw children

    box.connect("draw", _draw)
    return box

def _open_url(url):
    subprocess.Popen(["xdg-open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def _lbl(text, cls="field-label"):
    l = Gtk.Label(label=text)
    l.set_xalign(0)
    l.get_style_context().add_class(cls)
    return l

def _section(text):
    b = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    b.set_margin_top(16)
    lbl = _lbl(text, "section-title")
    b.pack_start(lbl, False, False, 0)
    sep = Gtk.Separator()
    b.pack_start(sep, False, False, 4)
    return b

def _hint(text):
    l = _lbl(text, "hint-label")
    l.set_margin_start(4)
    return l

def _field(label_text, widget):
    b = Gtk.Box(spacing=8)
    l = _lbl(label_text)
    l.set_size_request(200, -1)
    b.pack_start(l, False, False, 0)
    b.pack_start(widget, True, True, 0)
    return b

def _hex_to_rgb(hex_color):
    h = hex_color.lstrip("#")
    return tuple(int(h[i:i+2], 16) / 255.0 for i in (0, 2, 4))

# ── main application ───────────────────────────────────────────────────────────

class ThemeChangerApp(Gtk.Window):

    def __init__(self):
        super().__init__(title=_APP_NAME)
        self.set_default_size(980, 700)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.connect("delete-event", Gtk.main_quit)
        if os.path.isfile(_APP_LOGO):
            self.set_icon_from_file(_APP_LOGO)

        self._dark  = _state_get("dark", False)
        self._theme = THEME_DARK if self._dark else THEME_LIGHT
        self._cfg   = _config_load()
        self._status_lbl      = None
        self._status_timeout  = None
        self._nb              = None
        self._nb_hub_idx      = 4

        self._css_provider = Gtk.CssProvider()
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), self._css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_USER
        )
        self._apply_css()
        self._build_ui()
        self.show_all()
        # Force a redraw cycle after first presentation so GTK applies
        # background CSS correctly across all widgets.
        GLib.idle_add(self.queue_draw)

    # ── visual theme ────────────────────────────────────────────────────────────

    def _apply_css(self):
        self._css_provider.load_from_data(_build_css(self._theme).encode())

    def _toggle_theme(self, *_):
        self._dark  = not self._dark
        self._theme = THEME_DARK if self._dark else THEME_LIGHT
        _state_set("dark", self._dark)
        self._apply_css()
        child = self.get_child()
        if child:
            self.remove(child)
        self._build_ui()
        self.show_all()

    # ── UI construction ─────────────────────────────────────────────────────────

    def _build_ui(self):
        self._status_lbl = None
        inner = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        inner.pack_start(self._make_header(),    False, False, 0)
        inner.pack_start(self._make_notebook(),  True,  True,  0)
        inner.pack_start(self._make_statusbar(), False, False, 0)
        self.add(inner)

    def _make_header(self):
        t   = self._theme
        hdr = Gtk.Box(spacing=8)
        hdr.get_style_context().add_class("header-bar")
        hdr.set_margin_start(16)
        hdr.set_margin_end(16)

        icon_img = None
        if os.path.isfile(_APP_LOGO):
            try:
                pix = GdkPixbuf.Pixbuf.new_from_file_at_size(_APP_LOGO, 36, 36)
                icon_img = Gtk.Image.new_from_pixbuf(pix)
            except Exception:
                pass
        if icon_img is None:
            icon_img = Gtk.Label()
            icon_img.set_markup(f'<span font_desc="JetBrainsMono Nerd Font 22" foreground="{t["acc"]}">󰔯</span>')
        title = Gtk.Label()
        title.set_markup(
            f'<span foreground="{t["txt"]}" weight="bold" size="15000">{_APP_NAME}</span>'
        )
        hdr.pack_start(icon_img, False, False, 0)
        hdr.pack_start(title,    False, False, 6)
        hdr.pack_start(Gtk.Box(), True, True, 0)

        tog_icon = "󰖨" if self._dark else "󰖔"
        tog = Gtk.Button()
        tog_lbl = Gtk.Label()
        tog_lbl.set_markup(
            f'<span font_desc="JetBrainsMono Nerd Font 14">{tog_icon}</span>'
        )
        tog.add(tog_lbl)
        tog.get_style_context().add_class("open-btn")
        tog.connect("clicked", self._toggle_theme)
        hdr.pack_start(tog, False, False, 4)
        return hdr

    def _make_notebook(self):
        nb = Gtk.Notebook()
        nb.set_tab_pos(Gtk.PositionType.LEFT)
        nb.set_show_border(False)
        pages = [
            ("󰊠  Setup",       self._page_setup()),
            ("󰒓  Config",      self._page_config()),
            ("󰔯  Set Theme",   self._page_theme()),
            ("󰉏  Wallpaper",   self._page_wallpaper()),
            ("󰗓  Assets",      self._page_assets()),
            ("󰆦  vsHub",       self._page_hub()),
            ("󰘳  Commands",    self._page_commands()),
            ("󰋼  About",       self._page_about()),
        ]
        for label, page in pages:
            lbl = Gtk.Label()
            lbl.set_markup(
                f'<span font_desc="JetBrainsMono Nerd Font 11">{label}</span>'
            )
            lbl.set_xalign(0)
            nb.append_page(page, lbl)
        self._nb = nb
        self._nb_hub_idx = next(i for i, (lbl, _) in enumerate(pages) if "vsHub" in lbl)
        return nb

    def _make_statusbar(self):
        bar = Gtk.Box(spacing=8)
        bar.get_style_context().add_class("status-bar")
        self._status_lbl = Gtk.Label(label="Ready")
        self._status_lbl.set_xalign(0)
        bar.pack_start(self._status_lbl, True, True, 0)
        return bar

    def _set_status(self, msg, timeout=4):
        if self._status_lbl:
            self._status_lbl.set_text(msg)
            if self._status_timeout:
                GLib.source_remove(self._status_timeout)
                self._status_timeout = None
            if timeout:
                self._status_timeout = GLib.timeout_add_seconds(
                    timeout,
                    lambda: self._status_lbl.set_text("Ready") if self._status_lbl else False
                )

    # ── utilities ─────────────────────────────────────────────────────────────

    def _run_in_terminal(self, cmds, on_done=None):
        script = (
            " && ".join(cmds)
            + "; echo; echo 'Done — press Enter to close'; read"
        )
        try:
            proc = subprocess.Popen(["kitty", "-e", "bash", "-c", script])
            if on_done:
                def _wait():
                    proc.wait()
                    GLib.idle_add(on_done)
                threading.Thread(target=_wait, daemon=True).start()
        except Exception:
            pass

    def _reload_hub_tab(self, switch_to_hub=False):
        nb = self._nb
        if nb is None:
            return
        idx = self._nb_hub_idx
        was_current = nb.get_current_page() == idx
        nb.remove_page(idx)
        new_page = self._page_hub(auto_fetch=False)
        lbl = Gtk.Label()
        lbl.set_markup(
            '<span font_desc="JetBrainsMono Nerd Font 11">󰆦  vsHub</span>'
        )
        lbl.set_xalign(0)
        nb.insert_page(new_page, lbl, idx)
        new_page.show_all()
        if was_current or switch_to_hub:
            nb.set_current_page(idx)

