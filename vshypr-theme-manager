        # ── card helpers ──────────────────────────────────────────────────────
        _SWATCH_KEYS = ["bg", "accent", "red", "green", "teal", "mauve", "fg"]
        _THUMB_W, _THUMB_H = 160, 90

        def _make_swatch_row(colors: dict) -> Gtk.Box:
            row = Gtk.Box(spacing=3)
            row.set_halign(Gtk.Align.CENTER)
            for key in _SWATCH_KEYS:
                hex_col = colors.get(key)
                if not hex_col:
                    continue
                da = Gtk.DrawingArea()
                da.set_size_request(14, 14)
                try:
                    r, g, b = _hex_to_rgb(hex_col)
                except Exception:
                    continue
                def _draw_swatch(widget, cr, _r=r, _g=g, _b=b):
                    w = widget.get_allocated_width()
                    h = widget.get_allocated_height()
                    cr.set_source_rgb(_r, _g, _b)
                    cr.arc(w/2, h/2, min(w, h)/2, 0, 6.2832)
                    cr.fill()
                da.connect("draw", _draw_swatch)
                row.pack_start(da, False, False, 0)
            return row

        def _make_thumb(theme_dir: str) -> Gtk.Widget:
            for name in ("thumb.jpg", "thumb.png"):
                p = os.path.join(theme_dir, name)
                if os.path.isfile(p):
                    try:
                        pb = GdkPixbuf.Pixbuf.new_from_file_at_scale(p, _THUMB_W, _THUMB_H, False)
                        img = Gtk.Image.new_from_pixbuf(pb)
                        img.set_margin_bottom(4)
                        return img
                    except Exception:
                        pass
            # placeholder
            _ph_clr = _hex_to_rgb(t["hdr"])
            da = Gtk.DrawingArea()
            da.set_size_request(_THUMB_W, _THUMB_H)
            def _draw_ph(widget, cr, _c=_ph_clr):
                cr.set_source_rgb(*_c)
                cr.rectangle(0, 0, _THUMB_W, _THUMB_H)
                cr.fill()
            da.connect("draw", _draw_ph)
            return da

        def _find_theme_wallpaper(theme_dir: str):
            for ext in ("jpg", "png", "jpeg", "webp"):
                p = os.path.join(theme_dir, f"wallpaper.{ext}")
                if os.path.isfile(p):
                    return p
            return None

        def _apply_theme(name, wp=None):
            tc_py = os.path.join(self._cfg.get("theme_changer_dir", _USER_DATA_DIR), "vshypr-theme-manager.py")
            cmd = ["python3", tc_py, name] + ([wp] if wp else [])
            self._set_status(f"Applying {name}…")
            def _run():
                try:
                    r = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
                    msg = f"Theme '{name}' applied" if r.returncode == 0 else f"Error: {r.stderr[:80]}"
                except Exception as e:
                    msg = f"Error: {e}"
                GLib.idle_add(lambda: self._set_status(msg))
                GLib.idle_add(_refresh_active)
            threading.Thread(target=_run, daemon=True).start()

        def _pick_wallpaper_and_apply(name):
            dlg = Gtk.FileChooserDialog(
                title=f"Wallpaper para {name}", parent=self,
                action=Gtk.FileChooserAction.OPEN
            )
            dlg.add_button("Cancel", Gtk.ResponseType.CANCEL)
            dlg.add_button("Apply", Gtk.ResponseType.OK)
            ff = Gtk.FileFilter()
            ff.set_name("Images")
            for pat in ("*.jpg", "*.jpeg", "*.png", "*.webp"):
                ff.add_pattern(pat)
            dlg.add_filter(ff)
            wp_dir = self._cfg.get("wallpapers_dir", _DEFAULT_WP_DIR)
            if os.path.isdir(wp_dir):
                dlg.set_current_folder(wp_dir)
            ok  = dlg.run() == Gtk.ResponseType.OK
            wp  = dlg.get_filename() if ok else None
            dlg.destroy()
            if wp:
                _apply_theme(name, wp)

        def _make_theme_card(name: str, display_name: str, is_cur: bool, colors: dict, theme_dir: str) -> Gtk.Widget:
            card = _card_box(active=is_cur)
            card.set_size_request(180, -1)

