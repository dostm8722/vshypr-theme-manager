    def _page_assets(self):
        t      = self._theme
        tc_dir = self._cfg.get("theme_changer_dir", _USER_DATA_DIR)

        GROUPS = [
            {
                "title": "ROFI — RASI FILES",
                "hint":  "Theme config files for Rofi — target: ~/.config/rofi/",
                "items": [
                    ("config.rasi",            "assets/rofi/config.rasi",            "~/.config/rofi/config.rasi"),
                    ("spotlight.rasi",         "assets/rofi/spotlight.rasi",         "~/.config/rofi/spotlight.rasi"),
                    ("launchpad.rasi",         "assets/rofi/launchpad.rasi",         "~/.config/rofi/launchpad.rasi"),
                    ("config-keybinds.rasi",   "assets/rofi/config-keybinds.rasi",   "~/.config/rofi/config-keybinds.rasi"),
                    ("wallpaper-grid.rasi",    "assets/rofi/wallpaper-grid.rasi",    "~/.config/rofi/wallpaper-grid.rasi"),
                    ("theme-picker.rasi",      "assets/rofi/theme-picker.rasi",      "~/.config/rofi/theme-picker.rasi"),
                    ("wallpaper-picker.rasi",  "assets/rofi/wallpaper-picker.rasi",  "~/.config/rofi/wallpaper-picker.rasi"),
                ],
            },
            {
                "title": "WLOGOUT",
                "hint":  "Logout menu layout and SVG icons — target: ~/.config/wlogout/",
                "items": [
                    ("layout",        "assets/wlogout/layout",   "~/.config/wlogout/layout"),
                    ("icons/ (SVGs)", "assets/wlogout/icons/",   "~/.config/wlogout/icons/"),
                ],
            },
            {
                "title": "HYPRLAND SCRIPTS",
                "hint":  "Wallpaper daemon script (awww) — target: ~/.config/hypr/",
                "items": [
                    ("wallpaper.sh",  "assets/hypr/wallpaper.sh", "~/.config/hypr/wallpaper.sh"),
                ],
            },
        ]

        # ── helpers ───────────────────────────────────────────────────────────

        def _src_abs(src_rel):
            return os.path.join(tc_dir, src_rel)

        def _src_available(src_rel):
            s = _src_abs(src_rel)
            return os.path.isdir(s) if src_rel.endswith("/") else os.path.isfile(s)

        def _dst_installed(src_rel, dst):
            dst_abs = os.path.expanduser(dst)
            if src_rel.endswith("/"):
                if not os.path.isdir(dst_abs):
                    return False
                src_files = set(os.listdir(_src_abs(src_rel)))
                dst_files = set(os.listdir(dst_abs))
                return src_files.issubset(dst_files)
            return os.path.isfile(dst_abs)

        def _install(name, src_rel, dst, row_card, install_btn, status_lbl):
            src = _src_abs(src_rel)
            dst_abs = os.path.expanduser(dst)
            try:
                if src_rel.endswith("/"):
                    os.makedirs(dst_abs, exist_ok=True)
                    for f in os.listdir(src):
                        shutil.copy2(os.path.join(src, f), os.path.join(dst_abs, f))
                else:
                    os.makedirs(os.path.dirname(dst_abs), exist_ok=True)
                    shutil.copy2(src, dst_abs)
                # Update card to installed state
                row_card.get_style_context().remove_class("plugin-card")
                row_card.get_style_context().add_class("plugin-card-active")
                status_lbl.set_markup(f'<span foreground="{t["green"]}">●</span>')
                install_btn.set_label("Reinstall")
                self._set_status(f"Installed: {name}")
            except Exception as e:
                self._set_status(f"Error installing {name}: {e}")

        # ── layout ────────────────────────────────────────────────────────────
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.set_margin_start(24); outer.set_margin_end(24)
        outer.set_margin_top(20);   outer.set_margin_bottom(20)

        hdr_lbl = Gtk.Label()
        hdr_lbl.set_markup(
            f'<span foreground="{t["txt"]}" weight="bold" size="16000">Assets</span>'
        )
        hdr_lbl.set_halign(Gtk.Align.START)
        outer.pack_start(hdr_lbl, False, False, 0)

        sub = Gtk.Label()
        sub.set_markup(
            f'<span foreground="{t["dim"]}" size="12000">'
            f'Install bundled config files to their target locations</span>'
        )
        sub.set_halign(Gtk.Align.START)
        sub.set_margin_bottom(12)
        outer.pack_start(sub, False, False, 0)

        _all_btns = []   # (install_btn, src_rel, dst, name, row_card, status_lbl)

        for group in GROUPS:
            outer.pack_start(_section(group["title"]), False, False, 0)
            outer.pack_start(_hint(group["hint"]), False, False, 0)

            for name, src_rel, dst in group["items"]:
                available  = _src_available(src_rel)
                installed  = _dst_installed(src_rel, dst) if available else False

                card = _card_box(active=installed)
                card.set_margin_top(6)
                card.set_margin_bottom(2)

                row = Gtk.Box(spacing=10)
                row.set_margin_start(12); row.set_margin_end(12)
                row.set_margin_top(8);    row.set_margin_bottom(8)

                # status dot
                status_lbl = Gtk.Label()
                if not available:
                    status_lbl.set_markup(f'<span foreground="{t["mid"]}">○</span>')
                elif installed:
                    status_lbl.set_markup(f'<span foreground="{t["green"]}">●</span>')
                else:
                    status_lbl.set_markup(f'<span foreground="{t["yellow"]}">●</span>')
                row.pack_start(status_lbl, False, False, 0)

                # info
                info = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
                n_lbl = Gtk.Label()
                n_lbl.set_markup(
                    f'<span foreground="{t["txt"]}" weight="bold" size="13000">{name}</span>'
                )
                n_lbl.set_halign(Gtk.Align.START)
                d_lbl = Gtk.Label()
                d_lbl.set_markup(
                    f'<span foreground="{t["mid"]}" size="10500">{dst}</span>'
                )
                d_lbl.set_halign(Gtk.Align.START)
                info.pack_start(n_lbl, False, False, 0)
                info.pack_start(d_lbl, False, False, 0)
                row.pack_start(info, True, True, 0)

                # badge / button
                if not available:
                    badge = Gtk.Label()
                    badge.set_markup(
                        f'<span foreground="{t["mid"]}" size="10000" font_style="italic">not bundled</span>'
                    )
                    row.pack_start(badge, False, False, 0)
                else:
                    btn_label = "Reinstall" if installed else "Install"
                    install_btn = Gtk.Button(label=btn_label)
                    install_btn.get_style_context().add_class(
                        "open-btn" if installed else "save-btn"
                    )
                    _all_btns.append((install_btn, src_rel, dst, name, card, status_lbl))
                    row.pack_start(install_btn, False, False, 0)

                card.pack_start(row, False, False, 0)
                outer.pack_start(card, False, False, 0)

        # Wire install callbacks once all refs are collected
        for _btn, _sr, _d, _nm, _c, _sl in _all_btns:
            _btn.connect(
                "clicked",
                lambda *_, b=_btn, s=_sr, d=_d, n=_nm, c=_c, sl=_sl:
                    _install(n, s, d, c, b, sl)
            )

        # ── Install all missing ───────────────────────────────────────────────
        action_row = Gtk.Box(spacing=10)
        action_row.set_margin_top(20)
        action_row.pack_start(Gtk.Box(), True, True, 0)

        install_all = Gtk.Button()
        install_all.get_style_context().add_class("save-btn")
        lbl_all = Gtk.Label()
        lbl_all.set_markup(
            f'<span font_desc="JetBrainsMono Nerd Font 13">  Install all missing</span>'
        )
        install_all.add(lbl_all)

        def _install_all(*_):
            count = 0
            for install_btn, src_rel, dst, name, card, status_lbl in _all_btns:
                if _src_available(src_rel) and not _dst_installed(src_rel, dst):
                    _install(name, src_rel, dst, card, install_btn, status_lbl)
                    count += 1
            if count == 0:
                self._set_status("All assets already installed")
            else:
                self._set_status(f"Installed {count} asset(s)")

        install_all.connect("clicked", _install_all)
        action_row.pack_start(install_all, False, False, 0)
        outer.pack_start(action_row, False, False, 0)

        return _scrolled(outer)

